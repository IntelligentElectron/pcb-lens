{
  "name": "@intelligentelectron/pcb-lens",
  "version": "0.0.1",
  "description": "MCP server for IPC-2581 PCB layout analysis and review",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "pcb-lens": "./dist/index.js"
  },
  "scripts": {
    "setup": "bash scripts/download-fixtures.sh",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist bin",
    "compile": "bun build --compile --minify --define BUILD_VERSION=\"\\\"$(node -p 'require(\"./package.json\").version')\\\"\" src/index.ts --outfile bin/pcb-lens",
    "compile:darwin-arm64": "bun build --compile --minify --target=bun-darwin-arm64 --define BUILD_VERSION=\"\\\"$(node -p 'require(\"./package.json\").version')\\\"\" src/index.ts --outfile bin/pcb-lens-darwin-arm64",
    "compile:darwin-x64": "bun build --compile --minify --target=bun-darwin-x64 --define BUILD_VERSION=\"\\\"$(node -p 'require(\"./package.json\").version')\\\"\" src/index.ts --outfile bin/pcb-lens-darwin-x64",
    "compile:linux-arm64": "bun build --compile --minify --target=bun-linux-arm64 --define BUILD_VERSION=\"\\\"$(node -p 'require(\"./package.json\").version')\\\"\" src/index.ts --outfile bin/pcb-lens-linux-arm64",
    "compile:linux-x64": "bun build --compile --minify --target=bun-linux-x64 --define BUILD_VERSION=\"\\\"$(node -p 'require(\"./package.json\").version')\\\"\" src/index.ts --outfile bin/pcb-lens-linux-x64",
    "compile:windows-x64": "bun build --compile --minify --target=bun-windows-x64 --define BUILD_VERSION=\"\\\"$(node -p 'require(\"./package.json\").version')\\\"\" src/index.ts --outfile bin/pcb-lens-windows-x64.exe",
    "compile:darwin-universal": "npm run compile:darwin-arm64 && npm run compile:darwin-x64 && lipo -create bin/pcb-lens-darwin-arm64 bin/pcb-lens-darwin-x64 -output bin/pcb-lens-darwin-universal",
    "compile:all": "npm run compile:darwin-arm64 && npm run compile:darwin-x64 && npm run compile:linux-arm64 && npm run compile:linux-x64 && npm run compile:windows-x64 && lipo -create bin/pcb-lens-darwin-arm64 bin/pcb-lens-darwin-x64 -output bin/pcb-lens-darwin-universal",
    "prepublishOnly": "npm run type-check && npm run lint && npm test && npm run build"
  },
  "keywords": [
    "mcp",
    "pcb",
    "ipc-2581",
    "layout",
    "cadence",
    "allegro",
    "eda"
  ],
  "author": "Valentino Zegna <valentino.zegna@gmail.com> (https://github.com/IntelligentElectron)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IntelligentElectron/pcb-lens.git"
  },
  "bugs": {
    "url": "https://github.com/IntelligentElectron/pcb-lens/issues"
  },
  "homepage": "https://github.com/IntelligentElectron/pcb-lens#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "eslint": "^9.18.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.53.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  }
}
